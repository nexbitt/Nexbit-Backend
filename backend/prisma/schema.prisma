// ============================================================
// PASO 2: backend/prisma/schema.prisma
// Solo se agrega UNA línea: imagen_url
// El resto del archivo queda EXACTAMENTE igual
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model roles {
  id_rol      Int        @id @default(autoincrement())
  nombre      String     @unique(map: "nombre") @db.VarChar(50)
  descripcion String?    @db.VarChar(255)
  usuarios    usuarios[]
}

model usuarios {
  id_usuario                              Int                      @id @default(autoincrement())
  rol_id                                  Int
  nombre                                  String                   @db.VarChar(100)
  email                                   String                   @unique(map: "email") @db.VarChar(100)
  password                                String                   @db.VarChar(255)
  tipo_documento                          String?                  @db.VarChar(20)
  numero_documento                        String?                  @db.VarChar(20)
  telefono                                String?                  @db.VarChar(20)
  direccion                               String?                  @db.VarChar(255)
  activo                                  Boolean?                 @default(true)
  createdAt                               DateTime?                @default(now()) @map("created_at")
  updatedAt                               DateTime?                @default(now()) @updatedAt @map("updated_at")
  carrito                                 carrito[]
  movimientos_inventario                  movimientos_inventario[]
  pedidos_repartidor                      pedidos[]                @relation("pedidos_repartidor_idTousuarios")
  pedidos                                 pedidos[]
  seguimiento_pedido                      seguimiento_pedido[]
  rol                                     roles                    @relation(fields: [rol_id], references: [id_rol], map: "fk_usuario_rol")

  @@index([rol_id], map: "fk_usuario_rol")
}

model categorias {
  id_categoria Int         @id @default(autoincrement())
  nombre       String      @unique(map: "nombre") @db.VarChar(100)
  descripcion  String?     @db.VarChar(255)
  productos    productos[]
}

model proveedores {
  id_proveedor Int         @id @default(autoincrement())
  nit          String      @unique(map: "nit") @db.VarChar(20)
  nombre       String      @db.VarChar(100)
  telefono     String?     @db.VarChar(20)
  correo       String?     @db.VarChar(100)
  direccion    String?     @db.VarChar(255)
  activo       Boolean?    @default(true)
  productos    productos[]
}

model productos {
  id_producto            Int                      @id @default(autoincrement())
  categoria_id           Int?
  proveedor_id           Int?
  nombre                 String                   @db.VarChar(150)
  descripcion            String?                  @db.Text
  // ── NUEVO CAMPO ──────────────────────────────────────────
  imagen_url             String?                  @db.VarChar(500)
  // ─────────────────────────────────────────────────────────
  precio_compra          Decimal                  @default(0.00) @db.Decimal(12, 2)
  precio_venta           Decimal                  @default(0.00) @db.Decimal(12, 2)
  stock_actual           Int?                     @default(0)
  stock_minimo           Int?                     @default(0)
  activo                 Boolean?                 @default(true)
  createdAt              DateTime?                @default(now()) @map("created_at")
  updatedAt              DateTime?                @default(now()) @updatedAt @map("updated_at")
  carrito                carrito[]
  detalle_pedido         detalle_pedido[]
  movimientos_inventario movimientos_inventario[]
  categoria              categorias?              @relation(fields: [categoria_id], references: [id_categoria], onDelete: Restrict, map: "fk_prod_cat")
  proveedor              proveedores?             @relation(fields: [proveedor_id], references: [id_proveedor], onUpdate: Restrict, map: "fk_prod_prov")

  @@index([categoria_id], map: "fk_prod_cat")
  @@index([proveedor_id], map: "fk_prod_prov")
}

model pedidos {
  id_pedido                                Int                  @id @default(autoincrement())
  usuario_id                               Int
  repartidor_id                            Int?
  subtotal                                 Decimal?             @default(0.00) @db.Decimal(12, 2)
  impuesto                                 Decimal?             @default(0.00) @db.Decimal(12, 2)
  total                                    Decimal?             @default(0.00) @db.Decimal(12, 2)
  estado                                   pedidos_estado?      @default(PENDIENTE)
  direccion_entrega                        String?              @db.VarChar(255)
  notas_entrega                            String?              @db.VarChar(500)
  fecha_pedido                             DateTime?            @default(now())
  fecha_asignacion                         DateTime?
  fecha_entrega_est                        DateTime?
  fecha_entrega_real                       DateTime?
  detalle_pedido                           detalle_pedido[]
  facturas                                 facturas[]
  repartidor                               usuarios?            @relation("pedidos_repartidor_idTousuarios", fields: [repartidor_id], references: [id_usuario], onDelete: Restrict, onUpdate: Restrict, map: "fk_ped_repartidor")
  usuario                                  usuarios             @relation(fields: [usuario_id], references: [id_usuario], onUpdate: Restrict, map: "fk_ped_user")
  seguimiento_pedido                       seguimiento_pedido[]

  @@index([usuario_id], map: "fk_ped_user")
  @@index([repartidor_id], map: "fk_ped_repartidor")
}

model detalle_pedido {
  id_detalle_pedido Int       @id @default(autoincrement())
  pedido_id         Int
  producto_id       Int
  cantidad          Int
  precio_unitario   Decimal   @db.Decimal(12, 2)
  subtotal          Decimal   @db.Decimal(12, 2)
  pedido            pedidos   @relation(fields: [pedido_id], references: [id_pedido], onDelete: Cascade, onUpdate: Restrict, map: "fk_det_ped_id")
  producto          productos @relation(fields: [producto_id], references: [id_producto], onUpdate: Restrict, map: "fk_det_ped_prod")

  @@index([pedido_id], map: "fk_det_pedido")
  @@index([producto_id], map: "fk_det_producto")
}

model facturas {
  id_factura     Int            @id @default(autoincrement())
  pedido_id      Int
  numero_factura String         @unique(map: "numero_factura") @db.VarChar(50)
  subtotal       Decimal?       @default(0.00) @db.Decimal(12, 2)
  impuesto       Decimal?       @default(0.00) @db.Decimal(12, 2)
  total          Decimal?       @default(0.00) @db.Decimal(12, 2)
  estado         EstadoFactura? @default(EMITIDA)
  fecha_emision  DateTime?      @default(now())
  pedido         pedidos        @relation(fields: [pedido_id], references: [id_pedido], onUpdate: Restrict, map: "fk_fac_ped")

  @@index([pedido_id], map: "fk_fac_pedido")
}

model carrito {
  id_carrito  Int       @id @default(autoincrement())
  usuario_id  Int?
  session_id  String?   @db.VarChar(100)
  producto_id Int
  cantidad    Int       @default(1)
  producto    productos @relation(fields: [producto_id], references: [id_producto], onDelete: Cascade, onUpdate: Restrict, map: "fk_car_prod")
  usuario     usuarios? @relation(fields: [usuario_id], references: [id_usuario], onDelete: Cascade, onUpdate: Restrict, map: "fk_car_user")

  @@index([producto_id], map: "fk_car_prod")
  @@index([usuario_id], map: "fk_car_user")
}

model movimientos_inventario {
  id_movimiento   Int                                    @id @default(autoincrement())
  producto_id     Int
  usuario_id      Int
  tipo_movimiento movimientos_inventario_tipo_movimiento
  cantidad        Int                                    @default(0)
  referencia      String?                                @db.VarChar(100)
  fecha           DateTime?                              @default(now())
  productos       productos                              @relation(fields: [producto_id], references: [id_producto], onUpdate: Restrict, map: "fk_mov_producto")
  usuarios        usuarios                               @relation(fields: [usuario_id], references: [id_usuario], onUpdate: Restrict, map: "fk_mov_user")

  @@index([producto_id], map: "fk_mov_producto")
  @@index([usuario_id], map: "fk_mov_usuario")
}

model seguimiento_pedido {
  id_seguimiento  Int                                 @id @default(autoincrement())
  pedido_id       Int
  estado_anterior seguimiento_pedido_estado_anterior?
  estado_nuevo    seguimiento_pedido_estado_nuevo
  cambiado_por    Int
  notas           String?                             @db.VarChar(500)
  fecha           DateTime?                           @default(now())
  pedidos         pedidos                             @relation(fields: [pedido_id], references: [id_pedido], onDelete: Cascade, onUpdate: Restrict, map: "fk_seg_pedido")
  usuario         usuarios                            @relation(fields: [cambiado_por], references: [id_usuario], onUpdate: Restrict, map: "fk_seg_usuario")

  @@index([pedido_id], map: "fk_seg_pedido")
  @@index([cambiado_por], map: "fk_seg_usuario")
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  ANULADA
}

enum movimientos_inventario_tipo_movimiento {
  ENTRADA
  SALIDA
  AJUSTE
  VENTA
  COMPRA
}

enum seguimiento_pedido_estado_anterior {
  PENDIENTE
  CONFIRMADO
  ASIGNADO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum seguimiento_pedido_estado_nuevo {
  PENDIENTE
  CONFIRMADO
  ASIGNADO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum pedidos_estado {
  PENDIENTE
  CONFIRMADO
  ASIGNADO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}
